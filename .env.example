# ========== TELEGRAM SETTINGS ==========
# Get these from: https://my.telegram.org/auth
TELEGRAM_API_ID=YOUR_API_ID_HERE
TELEGRAM_API_HASH=YOUR_API_HASH_HERE

# Your Telegram phone number (with country code)
TELEGRAM_PHONE=+1234567890

# Channels to monitor for trading signals
# Use: python find_telegram_channels.py  to get correct IDs
# Option 1: Public channel usernames (recommended)
TELEGRAM_CHANNELS=["@forex_signals", "@trading_room"]
# Option 2: Private channel IDs 
# TELEGRAM_CHANNELS=["-1001234567890", "-1001234567891"]
# Option 3: Mix username and IDs
# TELEGRAM_CHANNELS=["@public_channel", "-1001234567890"]

# Telegram Bot for Notifications (Optional but recommended)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_NOTIFY_CHAT_ID=YOUR_CHAT_ID_HERE

# ========== MT5 SETTINGS ==========
# Your MT5 Account Login Number
MT5_LOGIN=123456

# Your MT5 Account Password
MT5_PASSWORD=your_password_here

# MT5 Server Name (e.g., "ICMarkets-Demo", "Exness-MT5", "MetaQuotes-Demo")
MT5_SERVER=ICMarkets-Demo

# MT5 Terminal Path (Optional, uses default if not specified)
# Windows: C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ========== TRADING SETTINGS ==========
TRADING_MODE=paper
MAX_DAILY_TRADES=10
MIN_SIGNAL_CONFIDENCE=0.7

# ========== RISK MANAGEMENT ==========
MAX_DRAWDOWN_PERCENT=5.0
RISK_PER_TRADE_PERCENT=1.0

# ========== ENHANCED PIPELINE SETTINGS ==========
# Fixed lot size for all trades
FIXED_LOT_SIZE=0.29

# Maximum concurrent open positions
MAX_OPEN_POSITIONS=15

# Signal lifecycle
# Pending signals expire after this many seconds if price does not enter the zone
SIGNAL_EXPIRY_SECONDS=600

# Monitoring loop interval in seconds
SIGNAL_POLL_INTERVAL=2

# Testing only: when true, skip confirmation checks after price enters zone
# Production recommendation: false
ENABLE_BYPASS_ENTRY_CONFIRMATION=true

# Entry Confirmation
ENABLE_ENTRY_CONFIRMATION=true
MIN_M5_REJECTION_CANDLE=true
MIN_BOS_REQUIRED=true
EMA_CONFIRMATION_REQUIRED=true

# Runner Mode & Break-Even
ENABLE_RUNNER_MODE=true
ENABLE_BREAK_EVEN=true

# ========== MONITORING & DATABASE ==========
ENABLE_METRICS=false
REDIS_URL=redis://redis:6379/0
ENABLE_NOTIFICATIONS=true
DATABASE_PATH=data/trading_bot.db

# ========== LEGACY SETTINGS (Deprecated but kept for compatibility) ==========
MAX_POSITION_SIZE=0.1
STOP_LOSS_PIPS=50
TAKE_PROFIT_PIPS=100
ORDER_TIMEOUT=30
MAX_RETRIES=3
